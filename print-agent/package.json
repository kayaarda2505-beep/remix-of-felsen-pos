{
  "name": "saints-print-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Local HTTP bridge that forwards POS print jobs to a Windows-installed thermal printer (Epson TM-T20III etc.) via ESC/POS.",
  "main": "dist/agent.cjs",
  "scripts": {
    "dev": "node --import tsx src/agent.ts",
    "build": "esbuild src/agent.ts --bundle --platform=node --target=node16 --format=cjs --alias:canvas=./src/canvas-stub.cjs --outfile=dist/agent.cjs",
    "start": "node dist/agent.cjs"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "esc-pos-encoder": "^2.1.0",
    "fastify": "^4.28.1",
    "qrcode-generator": "^1.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
