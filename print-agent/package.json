{
  "name": "saints-print-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Local HTTP bridge that forwards POS print jobs to a Windows-installed thermal printer (Epson TM-T20III etc.) via ESC/POS.",
  "main": "dist/agent.cjs",
  "scripts": {
    "dev": "node --import tsx src/agent.ts",
    "build": "esbuild src/agent.ts --bundle --platform=node --target=node20 --format=cjs --external:@thiagoelg/node-printer --outfile=dist/agent.cjs",
    "start": "node dist/agent.cjs"
  },
  "dependencies": {
    "@thiagoelg/node-printer": "^0.6.2",
    "esc-pos-encoder": "^2.1.0",
    "fastify": "^4.28.1",
    "@fastify/cors": "^9.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "@types/node": "^20.14.0"
  }
}
